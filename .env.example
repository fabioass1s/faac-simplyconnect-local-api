# Copie para .env e preencha. NUNCA versione o .env real.

# Credenciais da sua conta FAAC SimplyConnect (ficam só no servidor)
IDENTIFIER=voce@email.com
PASSWORD=sua-senha-faac

# Nome que aparece no app ao registrar/autorizar este "browser"
BROWSER_NAME=browser-aut

# Chave de acesso da SUA API. Gere uma forte, por ex.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=troque-por-uma-chave-aleatoria-longa

# Bind (deixe em localhost para uso local)
HOST=127.0.0.1
PORT=8000
